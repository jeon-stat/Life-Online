{
  "name": "life-online",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "web": "expo start --web",
    "prepare:build-info": "node ./tools/write-build-info.mjs",
    "export:web": "node ./tools/write-build-info.mjs && node ./node_modules/expo/bin/cli export --platform web",
    "sync:pages": "node ./tools/sync-pages.mjs",
    "deploy:pages": "node ./tools/write-build-info.mjs && node ./node_modules/expo/bin/cli export --platform web && node ./tools/sync-pages.mjs",
    "build:ios:dev": "eas build --platform ios --profile development",
    "test": "node --test"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.11",
    "@react-three/fiber": "^9.6.1",
    "expo": "^56.0.3",
    "expo-dev-client": "^56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-sensors": "^56.0.5",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2",
    "three": "^0.184.0"
  }
}
